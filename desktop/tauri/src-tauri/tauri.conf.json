{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OneMind",
  "version": "../../../package.json",
  "identifier": "io.github.0xliang233.onemind",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../renderer dev",
    "beforeBuildCommand": "pnpm --dir ../../renderer build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../../renderer/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OneMind",
        "width": 1040,
        "height": 760,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCRkYxOEVDMUREOTI3QjAKUldTd0o5a2Q3QmovNjl6enNkbWJjdlBpOVJyTkdLVzBRMDFxOCtBNWpDNWEreks3WTRJbCtiby8K",
      "endpoints": [
        "https://github.com/0xLiang233/oneMind/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
