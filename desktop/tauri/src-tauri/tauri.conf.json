{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OneMind",
  "version": "0.1.2",
  "identifier": "com.onemind.desktop.tauri",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../renderer dev",
    "beforeBuildCommand": "pnpm --dir ../../renderer build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../../renderer/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OneMind",
        "width": 1040,
        "height": 760,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
