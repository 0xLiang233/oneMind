{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OneMind Tauri Probe",
  "version": "0.1.5",
  "identifier": "com.onemind.tauriprobe",
  "build": {
    "frontendDist": "../probe-static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OneMind Tauri Probe",
        "width": 1040,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
